% ============================================================
% Colors by proof type
% ============================================================
\definecolor{idgreen}{RGB}{46,139,87}
\definecolor{thmblue}{RGB}{30,70,150}
\definecolor{reccyan}{RGB}{0,150,180}
\definecolor{derorange}{RGB}{210,120,20}
\definecolor{deryellow}{RGB}{180,160,30}
\definecolor{predred}{RGB}{180,30,30}
\definecolor{dissgray}{RGB}{120,120,120}
\definecolor{metapurple}{RGB}{120,60,160}
\definecolor{derphysred}{RGB}{180,50,50}
\definecolor{condorange}{RGB}{200,130,0}
\definecolor{bridgepurple}{RGB}{130,50,170}
\definecolor{valgray}{RGB}{100,100,100}
\definecolor{closuregold}{RGB}{180,150,0}

% Hyperref colors
\hypersetup{
  colorlinks=true,
  linkcolor=thmblue,
  citecolor=idgreen,
  urlcolor=derorange
}

% ============================================================
% Theorem-like environments (tcolorbox)
% ============================================================
\newcommand{\boxtag}[1]{\textnormal{\textsc{#1}}}

\tcbset{ptbox/.style={
  enhanced, breakable,
  before={\needspace{5\baselineskip}},
  before upper={\setlength{\parskip}{0.4em}},
  fonttitle=\bfseries
}}

\newtcolorbox{identitybox}[1][]{
  ptbox, colback=idgreen!5, colframe=idgreen,
  title={\boxtag{[id]} #1}
}
\newtcolorbox{theorembox}[1][]{
  ptbox, colback=thmblue!5, colframe=thmblue,
  title={\boxtag{[thm]} #1}
}
\newtcolorbox{reconstructedbox}[1][]{
  ptbox, colback=reccyan!5, colframe=reccyan,
  title={\boxtag{[rec]} #1}
}
\newtcolorbox{derivedphysbox}[1][]{
  ptbox, colback=derorange!5, colframe=derorange,
  title={\boxtag{[der-phys]} #1}
}
\newtcolorbox{derivedbox}[1][]{
  ptbox, colback=deryellow!5, colframe=deryellow!80!black,
  title={\boxtag{[der]} #1}
}
\newtcolorbox{predictionbox}[1][]{
  ptbox, colback=predred!5, colframe=predred,
  title={\boxtag{[pred]} #1}
}
\newtcolorbox{dissolutionbox}[1][]{
  ptbox, colback=dissgray!5, colframe=dissgray,
  title={\boxtag{[diss]} #1}
}
\newtcolorbox{metabox}[1][]{
  ptbox, colback=metapurple!5, colframe=metapurple,
  title={\boxtag{[meta]} #1}
}
\newtcolorbox{tradbox}[1][]{
  ptbox, colback=gray!5, colframe=gray!60,
  title={\boxtag{[trad]} #1}
}

% Status box for sections
\newtcolorbox{statusbox}{
  ptbox, colback=gray!3, colframe=gray!40,
  title={\boxtag{Status}}
}

% Ledger box for summaries
\newtcolorbox{ledgerbox}{
  ptbox, colback=thmblue!3, colframe=thmblue!40,
  title={}
}

% Theorem box with proof (blue)
\newtcolorbox{thmbox}[1][]{
  ptbox, colback=thmblue!5, colframe=thmblue,
  title={#1}
}

% Identity box (alternative name)
\newtcolorbox{idbox}[1][]{
  ptbox, colback=idgreen!5, colframe=idgreen,
  title={\boxtag{[id]} #1}
}

% Closure box
\newtcolorbox{closurebox}[1][]{
  ptbox, colback=condorange!5, colframe=condorange,
  title={\boxtag{[closure]} #1}
}

% Derived result box (monograph style)
\newtcolorbox{derbox}[1][]{
  ptbox, colback=derorange!5, colframe=derorange,
  title={\boxtag{[der]} #1}
}

% Bridge box (arithmetic -> physics)
\newtcolorbox{bridgebox}[1][]{
  ptbox, colback=bridgepurple!5, colframe=bridgepurple,
  title={\boxtag{[bridge]} #1}
}

% Conditional result box
\newtcolorbox{condbox}[1][]{
  ptbox, colback=condorange!5, colframe=condorange,
  title={\boxtag{[cond]} #1}
}

% Validation box
\newtcolorbox{valbox}[1][]{
  ptbox, colback=valgray!5, colframe=valgray,
  title={\boxtag{[val]} #1}
}

% Prediction box (alias for predictionbox)
\newtcolorbox{predbox}[1][]{
  ptbox, colback=predred!5, colframe=predred,
  title={\boxtag{[pred]} #1}
}

% PT-Closure box (gold)
\newtcolorbox{clbox}[1][]{
  ptbox, colback=closuregold!5, colframe=closuregold,
  title={\boxtag{[cl]} #1}
}

% ============================================================
% Standard amsthm environments
% ============================================================
\theoremstyle{plain}
\newtheorem{theorem}{Theorem}[section]
\newtheorem{proposition}[theorem]{Proposition}
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{corollary}[theorem]{Corollary}

\theoremstyle{definition}
\newtheorem{definition}[theorem]{Definition}
\newtheorem{example}[theorem]{Example}

\theoremstyle{remark}
\newtheorem{remark}[theorem]{Remark}
\newtheorem{hypothesis}[theorem]{Hypothesis}
\newtheorem{conjecture}[theorem]{Conjecture}

